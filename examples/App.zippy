<script>
  import Counter from "./Counter.zippy";
  const name = signal("Zippy");

  const items = signal(["a", "b", "c"]);
  const show = signal(true);
</script>

<style>
  h1 { color: #42b883; }
</style>

<template>
  <div>
    <h1>Hello, {name}!</h1>
    <Counter start={5} />

    {#if show}
      <p>Visible section</p>
    {/if}

    <ul>
      {#each items as item}
        <li>{item}</li>
      {/each}
    </ul>
  </div>
</template>
